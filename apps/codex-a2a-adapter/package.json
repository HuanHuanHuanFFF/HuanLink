{
  "name": "@huanlink/codex-a2a-adapter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf --glob dist \"*.tsbuildinfo\" \"*.tsbuildinfo.*\"",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:real": "vitest run --config vitest.real.config.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@a2a-js/sdk": "1.0.0-beta.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3"
  }
}
