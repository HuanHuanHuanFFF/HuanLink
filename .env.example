HUANLINK_EVENT_LOG_BASE_DIR=.huanlink
HUANLINK_EVENT_LOG_NEXT_SEQ_CACHE_SIZE=256
HUANLINK_AGENT_DEFAULT_MAX_STEPS=8
HUANLINK_LOG_LEVEL=info

# Phase 4 real QQ ingress through LLBot/NapCat OneBot 11 forward WebSocket.
HUANLINK_ONEBOT_WS_URL=ws://127.0.0.1:3001/
HUANLINK_ONEBOT_ACCESS_TOKEN=
HUANLINK_ONEBOT_GROUP_ID=
HUANLINK_ONEBOT_COMMAND_PREFIX=/huanlink

# Real Codex A2A Adapter.
HUANLINK_CODEX_A2A_ORIGIN=http://127.0.0.1:4000
HUANLINK_CODEX_A2A_SKILL_ID=codex-code-task

# Required by the real OpenAI Agents JS MainAgent.
OPENAI_API_KEY=
